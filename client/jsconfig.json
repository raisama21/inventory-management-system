{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@components/*": [
                "src/components/*"
            ],
            "@pages/*": [
                "src/pages/*"
            ],
            "@styles/*": [
                "src/styles/*"
            ],
            "@/*": [
                "src/*"
            ],
            "@layouts/*": [
                "src/layouts/*"
            ],
            "@invoice/*": [
                "src/pages/invoice/*"
            ]
        }
    }
}